<!DOCTYPE html>
<html lang="en">

<head>
  <meta name="color-scheme" content="light dark">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
  {{if .FaviconPath}}
  <link rel="icon" type="image/x-icon" href={{.FaviconPath}}>
  {{end}}

  {{template "commonCSS" .}}
  {{template "commonJS" .}}
  <style>
    /* ── Home Page Layout ───────────────────────────────────────────────── */
    #sidebar-toggle {
      display: none !important;
    }
    
    .home-header {
      margin-bottom: 4rem;
    }

    .home-header h1 {
      margin-top: 0;
      font-size: 2.5rem;
      letter-spacing: -.03em;
    }

    /* Search Bar */
    .search-bar {
      margin-top: 1.5rem;
      position: relative;
      width: 100%;
      max-width: 450px;
    }

    .search-bar svg {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      pointer-events: none;
      flex-shrink: 0;
    }

    .search-bar input {
      width: 100%;
      padding: 0.75rem 1.15rem 0.75rem 2.75rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-alt);
      color: var(--text);
      font-family: var(--font-serif);
      font-size: 1rem;
      transition: border-color var(--ease), box-shadow var(--ease);
      box-sizing: border-box;
    }

    .search-bar input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    /* Search Status & Helpers */
    .search-status {
      margin-top: 0;
      margin-bottom: 1.25rem;
      font-size: 0.875rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      min-height: 1.25em;
      text-align: left;
    }

    #search-sentinel {
      width: 100%;
      height: 20px;
      visibility: hidden;
    }

    /* Card Grid */
    .page-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .content {
      max-width: 1200px;
    }

     .page-card {
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      text-decoration: none !important;
      color: inherit;
      transition: transform var(--ease), box-shadow var(--ease), border-color var(--ease);
    }
    .page-card * {
      text-decoration: none !important;
    }

    .page-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
      border-color: var(--accent);
    }

    :root[data-theme="dark"] .page-card:hover {
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3);
    }

    .card-image {
      width: 100%;
      height: 150px;
      border-bottom: 1px solid var(--border);
      overflow: hidden;
    }

    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      margin: 0;
      border: none;
      border-radius: 0;
    }

    .card-content {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .card-content h2 {
      font-size: 1.25rem;
      margin-top: 0;
      margin-bottom: 0.5rem;
      border-bottom: none;
      padding-bottom: 0;
      color: var(--text);
      transition: color var(--ease);
    }

    .page-card:hover .card-content h2 {
      color: var(--accent);
    }

    .card-content .overview {
      font-size: 0.925rem;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
      line-height: 1.6;
      flex-grow: 1;
      
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-meta {
      margin-top: auto;
      font-size: 0.8rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      border-top: 1px solid var(--border);
      padding-top: 0.75rem;
    }

    .no-posts, .no-results {
      grid-column: 1 / -1;
      padding: 4.5rem 2rem;
      text-align: center;
      color: var(--text-muted);
      background: var(--bg-alt);
      border-radius: var(--radius);
      border: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }
    
    .no-posts svg, .no-results svg {
      opacity: 0.5;
    }
    /* Category Tag */
    .card-category {
      display: inline-block;
      font-size: 0.75rem;
      font-family: var(--font-mono);
      background: var(--surface);
      color: var(--accent);
      padding: 0.15rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 0.75rem;
      width: fit-content;
      transition: background var(--ease), border-color var(--ease);
      cursor: pointer;
    }
    
    .card-category:hover {
      background: var(--accent-dim);
      border-color: var(--accent);
    }

    /* Search Controls Layout */
    .search-controls {
      display: flex;
      flex-wrap: nowrap;
      gap: 1rem;
      margin-top: 2rem;
      width: 100%;
      max-width: 600px;
    }

    /* Category Dropdown */
    .category-filter {
      padding: 0.75rem 1.15rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-alt);
      color: var(--text);
      font-family: var(--font-serif);
      font-size: 1rem;
      transition: border-color var(--ease), box-shadow var(--ease);
      cursor: pointer;
      appearance: none; /* Removes default OS styling */
      min-width: 150px;
    }

    .category-filter:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }
  </style>
  <script>
    (function () {
      "use strict";

      const MIN_CHARS = 3;
      const BATCH_SIZE = 20;

      // 1. Inject JSON array with Category
      const allPages = [
        {{range .AllPosts}}{
          url: {{.URL}},
          title: {{.Title}},
          img: {{.ImgPath}},
          overview: {{.OverviewText}},
          category: {{.Category}},
          date: {{.ModifiedAt}},
          createdAt: {{.CreatedAt}}
        },{{end}}
      ];

      // 2. Formatter for ISO Dates
      const formatISO = (iso) => {
        if (!iso) return '';
        const d = new Date(iso);
        return isNaN(d) ? iso : d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
      };

      document.addEventListener("DOMContentLoaded", function () {
        const input = document.getElementById("page-search");
        const catFilter = document.getElementById("category-filter");
        const latestPostsContainer = document.getElementById("latest-posts");
        const searchResultsContainer = document.getElementById("search-results-container");
        const grid = document.getElementById("page-grid");
        const status = document.getElementById("search-status");
        const sentinel = document.getElementById("search-sentinel");
        const noResults = document.getElementById("no-results");

        if (!input || !grid || !latestPostsContainer) return;

        let filteredPages = [];
        let currentIndex = 0;

        // Populate Category Dropdown Dynamically
        if (catFilter) {
          // Extract unique categories, remove empty ones, and sort alphabetically
          const categories = [...new Set(allPages.map(p => p.category).filter(Boolean))].sort();
          categories.forEach(c => {
            const opt = document.createElement("option");
            opt.value = c.toLowerCase();
            opt.textContent = c;
            catFilter.appendChild(opt);
          });
        }

        const renderCard = (p) => {
          const imgHtml = p.img ? `<div class="card-image"><img src="${p.img}" alt="${p.title}" loading="lazy"></div>` : '';
          const catHtml = p.category ? `<span class="card-category">${p.category}</span>` : '';
          
          return `
            <a href="${p.url}" class="page-card">
              ${imgHtml}
              <div class="card-content">
                ${catHtml}
                <h2>${p.title}</h2>
                <p class="overview">${p.overview}</p>
                <div class="card-meta">
                  <span class="date">Created: ${formatISO(p.createdAt)} | Updated: ${formatISO(p.date)}</span>
                </div>
              </div>
            </a>`;
        };

        const loadNextBatch = () => {
          const nextBatch = filteredPages.slice(currentIndex, currentIndex + BATCH_SIZE);
          if (nextBatch.length === 0) return;

          const fragment = document.createDocumentFragment();
          nextBatch.forEach(p => {
            const temp = document.createElement('div');
            temp.innerHTML = renderCard(p);
            fragment.appendChild(temp.firstElementChild);
          });
          grid.appendChild(fragment);
          currentIndex += nextBatch.length;
        };

        const observer = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting && filteredPages.length > currentIndex) {
            loadNextBatch();
          }
        }, { rootMargin: '200px' });
        if (sentinel) observer.observe(sentinel);

        // Unified Filtering Logic
        const applyFilters = () => {
          const raw = input.value;
          const query = raw.toLowerCase().trim();
          const selectedCat = catFilter ? catFilter.value.toLowerCase() : "";

          // Revert to Static View if query is too short AND no category is selected
          if (query.length < MIN_CHARS && selectedCat === "") {
            latestPostsContainer.style.display = "block";
            searchResultsContainer.style.display = "none";
            grid.innerHTML = '';
            status.textContent = "";
            return;
          }

          // Switch to Dynamic View
          latestPostsContainer.style.display = "none";
          searchResultsContainer.style.display = "block";

          filteredPages = allPages.filter(p => {
            const matchesText = query === "" || p.title.toLowerCase().includes(query) || p.overview.toLowerCase().includes(query);
            const matchesCat = selectedCat === "" || (p.category && p.category.toLowerCase() === selectedCat);
            return matchesText && matchesCat;
          });

          currentIndex = 0;
          grid.innerHTML = '';

          // Handle Results state
          if (filteredPages.length === 0) {
            noResults.style.display = "block";
            sentinel.style.display = "none";
            status.textContent = "";
          } else {
            noResults.style.display = "none";
            sentinel.style.display = "block";
            loadNextBatch();
            
            let statStr = `${filteredPages.length} ${filteredPages.length === 1 ? 'result' : 'results'}`;
            if (query) statStr += ` for '${raw.trim()}'`;
            if (selectedCat) statStr += ` in '${catFilter.options[catFilter.selectedIndex].text}'`;
            status.textContent = statStr;
          }
        };

        input.addEventListener("input", applyFilters);
        if (catFilter) catFilter.addEventListener("change", applyFilters);

        // Click delegation for category badges
        const gridsContainer = document.querySelectorAll(".page-grid");
        gridsContainer.forEach(gc => {
          gc.addEventListener("click", function(e) {
            if (e.target.classList.contains("card-category")) {
              e.preventDefault();
              if (catFilter) {
                catFilter.value = e.target.textContent.toLowerCase();
                catFilter.dispatchEvent(new Event("change"));
                
                const searchOffset = document.querySelector(".search-controls").offsetTop - 80;
                window.scrollTo({ top: searchOffset, behavior: 'smooth' });
              }
            }
          });
        });

        // Parse any statically rendered ISO dates (from Go template logic)
        document.querySelectorAll('.card-meta .date').forEach(el => {
          el.textContent = el.textContent.replace(/\d{4}-\d{2}-\d{2}T[.Z\d:\+\-]+/g, match => formatISO(match));
        });
      });
    })();
  </script>
</head>

<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="navbar">
    {{block "navbar" .}}{{end}}
  </div>

  <main id="main-content" class="content">
    {{block "content" .}}{{.Content}}{{end}}
  </main>

  <footer class="footer">
    {{block "footer" .}}{{end}}
  </footer>
</body>

</html>
