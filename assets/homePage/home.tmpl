{{define "content"}}
<div class="home-header">
  <h1>{{if .SiteName}}{{.SiteName}}{{else}}Welcome{{end}}</h1>
  <p>{{if .SiteDescription}}{{.SiteDescription}}{{else}}Welcome to this site! Unfortunately, owner didn't set and description.{{end}}</p>
  <div class="search-controls">
  <div class="search-bar" style="margin-top: 0; flex-grow: 1;">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input type="text" id="page-search" placeholder="Search posts..." autocomplete="off">
  </div>
  
  <select id="category-filter" class="category-filter">
    <option value="">All Categories</option>
    </select>
  </div>
  </div>

<div id="latest-posts">
  <div class="page-grid">
    {{range .LatestPosts}}
    <a href="{{.URL}}" class="page-card">
      {{if .ImgPath}}
      <div class="card-image">
        <img src="{{.ImgPath}}" alt="{{.Title}}" loading="lazy">
      </div>
      {{end}}
      {{if .Category}}
      <span class="card-category">{{.Category}}</span>
      {{end}}
      <div class="card-content">
        <h2>{{.Title}}</h2>
        <p class="overview">{{.OverviewText}}</p>
        <div class="card-meta">
          <span class="date">Created: {{.CreatedAt}} | Updated: {{.ModifiedAt}}</span>
        </div>
      </div>
    </a>
    {{end}}

    {{if not .LatestPosts}}
    <div class="no-posts">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="15" x2="15" y2="15"></line></svg>
      <p>No posts available yet.</p>
    </div>
    {{end}}
  </div>
</div>

<div id="search-results-container" style="display: none;">
<h2 id="search-status" class="search-status"></h2>
  
  <div id="page-grid" class="page-grid"></div>
  
  <div id="no-results" class="no-results" style="display: none;">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    <p>No posts found.</p>
  </div>
  
  <div id="search-sentinel"></div>
</div>
{{end}}
