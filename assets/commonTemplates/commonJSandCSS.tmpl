/* Inline Common JS and CSS to save on performance. */
{{define "commonCSS"}}
<style>
/* ── Light tokens ───────────────────────────────────────────────────── */
:root {
  --font-serif: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --font-mono: ui-monospace, Menlo, Monaco, "Cascadia Mono", "Segoe UI Mono", "Roboto Mono", monospace;

  --bg: #f4f4f5;
  --bg-alt: #e4e4e7;
  --surface: #ffffff;
  --border: #d4d4d8;
  --text: #09090b;
  --text-muted: #52525b;
  --accent: #27272a;
  --accent-dim: #f4f4f5;
  --link: #3b82f6;
  --link-vis: #6366f1;
  --code-bg: #f4f4f5;
  --shadow-nav: 0 1px 0 var(--border), 0 2px 12px rgba(0, 0, 0, .04);

  --sidebar-w: 260px;
  --nav-h: 52px;
  --radius: 6px;
  --ease: 200ms ease;
}

/* ── Dark tokens ────────────────────────────────────────────────────── */
:root[data-theme="dark"] {
  --bg: #151515;
  --bg-alt: #222222;
  --surface: #1f1f1f;
  --border: #333333;
  --text: #eaeaea;
  --text-muted: #a1a1aa;
  --accent: #e4e4e7;
  --accent-dim: #2d2d2d;
  --link: #60a5fa;
  --link-vis: #818cf8;
  --code-bg: #1a1a1a;
  --shadow-nav: 0 1px 0 var(--border), 0 4px 12px rgba(0, 0, 0, .3);
}

/* ── Reset ──────────────────────────────────────────────────────────── */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
  scrollbar-color: var(--border) transparent;
  scrollbar-width: thin;
  overflow-x: hidden;
}

body {
  font-family: var(--font-serif);
  background: var(--bg);
  color: var(--text);
  line-height: 1.75;
  min-height: 100dvh;
  display: grid;
  grid-template-rows: var(--nav-h) 1fr auto;
  grid-template-columns: var(--sidebar-w) 1fr;
  grid-template-areas: "nav nav" "side main" "foot foot";
  transition: background var(--ease), color var(--ease);
  overscroll-behavior-y: none;
}

/* ── Sidebar collapsed (Desktop) ────────────────────────────────────── */
body.sidebar-hidden {
  grid-template-columns: 0 1fr;
}

body.sidebar-hidden .sidebar {
  opacity: 0;
  pointer-events: none;
  overflow: hidden;
  padding: 0;
  border: none;
}

/* ── Navbar ─────────────────────────────────────────────────────────── */
.navbar {
  grid-area: nav;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 1050;
  display: flex;
  align-items: center;
  gap: .9rem;
  padding: 0 1.25rem;
  height: var(--nav-h);
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  box-shadow: var(--shadow-nav);
  transition: background var(--ease), border-color var(--ease);
}

.sidebar-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border: none;
  background: none;
  cursor: pointer;
  color: var(--text-muted);
  border-radius: var(--radius);
  flex-shrink: 0;
  transition: color var(--ease), background var(--ease);
  padding: 0;
}

.sidebar-toggle:hover {
  color: var(--text);
  background: var(--bg-alt);
}

.sidebar-toggle svg,
.theme-toggle svg {
  stroke: currentColor;
  color: inherit;
}

/* GLOBALLY KILL HAMBURGER */
#nav-hamburger,
.nav-hamburger {
  display: none !important;
}

.site-name {
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -.025em;
  color: var(--text);
  text-decoration: none;
  white-space: nowrap;
}

.site-name span {
  color: var(--accent);
}

.navbar nav {
  display: flex;
  align-items: center;
  gap: .1rem;
}

.navbar nav a {
  font-family: var(--font-serif);
  font-size: .875rem;
  color: var(--text-muted);
  text-decoration: none;
  padding: .3rem .65rem;
  border-radius: var(--radius);
  transition: color var(--ease), background var(--ease);
  white-space: nowrap;
}

.navbar nav a:hover,
.navbar nav a.active {
  color: var(--text);
  background: var(--bg-alt);
}

.navbar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: .5rem;
  flex-shrink: 0;
}

.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: 1px solid var(--border);
  background: var(--bg-alt);
  border-radius: 50%;
  cursor: pointer;
  color: var(--text-muted);
  transition: color var(--ease), background var(--ease), border-color var(--ease);
  flex-shrink: 0;
}

.theme-toggle:hover {
  color: var(--text);
  border-color: var(--text-muted);
}

.icon-sun {
  display: none;
}

.icon-moon {
  display: block;
}

:root[data-theme="dark"] .icon-sun {
  display: block;
}

:root[data-theme="dark"] .icon-moon {
  display: none;
}

/* ── Sidebar ────────────────────────────────────────────────────────── */
.sidebar-wrap {
  grid-area: side;
  display: contents;
}

.sidebar {
  grid-area: side;
  position: sticky;
  top: var(--nav-h);
  height: calc(100dvh - var(--nav-h));
  overflow-y: auto;
  overflow-x: hidden;
  padding: 1.4rem .85rem;
  border-right: 1px solid var(--border);
  background: var(--bg-alt);
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  z-index: 100;
  transition: transform var(--ease), opacity var(--ease), background var(--ease), border-color var(--ease);
}

.sidebar-label {
  font-family: var(--font-mono);
  font-size: .67rem;
  letter-spacing: .09em;
  text-transform: uppercase;
  color: var(--text-muted);
  padding: .3rem .4rem;
  margin-top: 1.25rem;
  margin-bottom: .3rem;
}

.sidebar-label:first-child {
  margin-top: 0;
}

.sidebar-toc {
  list-style: none;
}

.sidebar-toc li {
  margin: 0;
}

.sidebar-toc a {
  display: block;
  font-size: .875rem;
  color: var(--text-muted);
  text-decoration: none;
  padding: .3rem .45rem;
  border-left: 2px solid transparent;
  border-radius: 0 var(--radius) var(--radius) 0;
  line-height: 1.4;
  transition: all var(--ease);
}

.sidebar-toc a:hover {
  color: var(--text);
  background: var(--surface);
  border-left-color: var(--border);
}

.sidebar-toc a.active {
  color: var(--accent);
  background: var(--accent-dim);
  border-left-color: var(--accent);
}

.sidebar-toc .toc-h2>a {
  padding-left: .45rem;
  font-weight: 600;
  font-size: .875rem;
}

.sidebar-toc .toc-h3>a {
  padding-left: 1.15rem;
  font-size: .845rem;
}

.sidebar-toc .toc-h4>a {
  padding-left: 1.85rem;
  font-size: .82rem;
}

.mobile-main-nav {
  display: none;
}

/* ── Main content ───────────────────────────────────────────────────── */
.content {
  grid-area: main;
  padding: 2.25rem 3rem 3rem;
  max-width: 800px;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
  /* Add top padding to account for fixed navbar */
  margin-top: var(--nav-h);
}

.content>nav:first-child {
  display: none;
}

/* Prose Elements */
.content h1,
.content h2,
.content h3,
.content h4,
.content h5,
.content h6 {
  line-height: 1.25;
  letter-spacing: -.02em;
  color: var(--text);
  margin-top: 2rem;
  margin-bottom: .5rem;
}

.content h1 {
  font-size: 2rem;
  margin-top: 0;
}

.content h2 {
  font-size: 1.45rem;
  border-bottom: 1px solid var(--border);
  padding-bottom: .35rem;
  margin-top: 2.5rem;
}

.content h3 {
  font-size: 1.15rem;
}

.content p {
  margin-bottom: 1rem;
  max-width: 70ch;
}

.content a {
  color: var(--link);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
  transition: color var(--ease);
}

.content a:visited {
  color: var(--link-vis);
}

.content a:hover {
  color: var(--accent);
}

.content ul,
.content ol {
  padding-left: 1.4rem;
  margin-bottom: 1rem;
  max-width: 70ch;
}

.content li {
  margin-bottom: .2rem;
}

.content li>ul,
.content li>ol {
  margin-top: .2rem;
  margin-bottom: 0;
}

.content blockquote {
  margin: 1.25rem 0;
  padding: .7rem 1.1rem;
  border-left: 3px solid var(--accent);
  background: var(--accent-dim);
  border-radius: 0 var(--radius) var(--radius) 0;
  color: var(--text-muted);
  font-style: italic;
}

.content code {
  font-family: var(--font-mono);
  font-size: .845em;
  background: var(--code-bg);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: .1em .38em;
}

.content pre {
  background: var(--code-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.15rem;
  overflow-x: auto;
  margin-bottom: 1.2rem;
  scrollbar-width: thin;
  transition: background var(--ease), border-color var(--ease);
  position: relative;
}

.content pre code {
  background: none;
  border: none;
  padding: 0;
  font-size: .84rem;
  line-height: 1.6;
}

.content pre span[style] {
  transition: filter var(--ease);
}

.content img {
  max-width: 100%;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  display: block;
  margin: 1rem 0;
  cursor: zoom-in;
}

/* ── Custom JS Features ──────────────────────────────────────────────── */


.content table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 1.2rem;
  font-size: .9rem;
}

.content th,
.content td {
  text-align: left;
  padding: .45rem .8rem;
  border: 1px solid var(--border);
}

.content th {
  background: var(--bg-alt);
  font-weight: 600;
}

.content tr:nth-child(even) td {
  background: var(--bg-alt);
}

.content hr {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2rem 0;
}

/* ── Footer ─────────────────────────────────────────────────────────── */
.footer {
  grid-area: foot;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: .5rem;
  padding: .85rem 1.5rem;
  font-size: .78rem;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  background: var(--surface);
  transition: background var(--ease), border-color var(--ease);
}

.footer a {
  color: var(--text-muted);
  text-decoration: none;
}

.footer a:hover {
  color: var(--accent);
}

/* ── Responsive & Mobile Nav Rules ──────────────────────────────────── */
@media (max-width: 768px) {

  body {
    grid-template-columns: 1fr;
    grid-template-areas: "nav" "main" "foot";
  }

  body.sidebar-hidden {
    grid-template-columns: 1fr;
  }

  /* Scroll lock: prevent scrolling the page behind the sidebar */
  body.mobile-sidebar-open {
    overflow: hidden;
  }

  /* Ensure the toggle button is shown on mobile */
  #sidebar-toggle {
    display: flex !important;
  }

  /* Redefine Sidebar layout for mobile slide-in */
  .sidebar-wrap {
    display: block !important;
    position: fixed;
    top: var(--nav-h);
    left: 0;
    width: 280px;
    height: calc(100dvh - var(--nav-h));
    z-index: 1000;
    transform: translateX(-100%);
    transition: transform var(--ease);
  }

  body.mobile-sidebar-open .sidebar-wrap {
    transform: translateX(0);
  }

  .sidebar {
    display: block !important;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--surface);
    border-right: 1px solid var(--border);
    box-shadow: 2px 0 12px rgba(0, 0, 0, 0.15);
  }

  .sidebar-overlay {
    position: fixed;
    top: var(--nav-h);
    left: 0;
    width: 100vw;
    height: calc(100dvh - var(--nav-h));
    background: rgba(0, 0, 0, 0.4);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--ease), visibility var(--ease);
    backdrop-filter: blur(2px);
  }

  body.mobile-sidebar-open .sidebar-overlay {
    opacity: 1;
    visibility: visible;
  }

  .navbar {
    flex-wrap: wrap;
    height: auto;
    min-height: var(--nav-h);
    padding-bottom: 0;
  }

  /* Hide original main-nav top links so we use the cloned ones in the sidebar */
  .navbar nav#main-nav {
    display: none !important;
  }

  /* Style the cloned main nav links for the mobile sidebar */
  .mobile-main-nav {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .mobile-main-nav a {
    font-size: 1.05rem;
    color: var(--text);
    text-decoration: none;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius);
    transition: background var(--ease), color var(--ease);
  }

  .mobile-main-nav a:hover,
  .mobile-main-nav a.active {
    background: var(--bg-alt);
    color: var(--accent);
  }

  .content {
    padding: 1.5rem 1rem 2.5rem;
    overflow-x: hidden;
  }

  .footer {
    flex-direction: column;
    align-items: flex-start;
    gap: .35rem;
  }
}

/* Touch cleanup */
button {
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}

/* ── Skip Link ──────────────────────────────────────────────────────── */
.skip-link {
  position: absolute;
  top: -60px;
  left: 0;
  background: var(--accent);
  color: var(--bg);
  padding: 8px 16px;
  z-index: 9999;
  transition: top var(--ease);
  text-decoration: none;
  font-weight: bold;
}
.skip-link:focus { top: 0; }

/* ── Print Stylesheet ───────────────────────────────────────────────── */
@media print {
  .navbar, .sidebar-wrap, .footer, .reading-progress-bar, .back-to-top, .copy-code-btn, .sidebar-toggle, .theme-toggle, .skip-link {
    display: none !important;
  }
  body, .content {
    background: white !important;
    color: black !important;
    display: block;
    margin: 0; padding: 0;
  }
  .content p, .content ul, .content ol { max-width: none; }
  a { text-decoration: none; color: black; }
  pre, blockquote { border: 1px solid #ccc; page-break-inside: avoid; }
}

</style>
{{end}}
{{define "commonJS"}}
<script>
  /* common.js — updated features */
(function () {
  "use strict";

  /* ── Theme ─────────────────────────────────────────────────────────── */
  var THEME_KEY = "theme";

  function getPreferred() {
    var saved = localStorage.getItem(THEME_KEY);
    if (saved) return saved;
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  }

  function applyTheme(theme) {
    if (theme === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
    } else {
      document.documentElement.removeAttribute("data-theme");
    }

    if (
      document.readyState === "interactive" ||
      document.readyState === "complete"
    ) {
      syncCodeTheme(theme);
    }
  }

  /* ── Dynamic Code Highlight Color Script ───────────────────────────── */
  function syncCodeTheme(theme) {
    document.querySelectorAll(".content pre").forEach(function (pre) {
      if (theme === "dark") {
        if (!pre.dataset.origBg)
          pre.dataset.origBg = pre.style.backgroundColor || "";
        pre.style.backgroundColor = "var(--code-bg)";

        pre.querySelectorAll('span[style*="color"]').forEach(function (span) {
          span.style.filter =
            "invert(1) hue-rotate(180deg) brightness(1.3) contrast(1.1)";
        });
      } else {
        if (pre.dataset.origBg !== undefined)
          pre.style.backgroundColor = pre.dataset.origBg;
        pre.querySelectorAll('span[style*="color"]').forEach(function (span) {
          span.style.filter = "";
        });
      }
    });
  }

  applyTheme(getPreferred());

  /* ── Sidebar state ──────────────────────────────────────────────────── */
  var SIDEBAR_KEY = "sidebar";

  function getSidebarState() {
    return localStorage.getItem(SIDEBAR_KEY) !== "hidden";
  }

  function applySidebar(visible) {
    if (visible) {
      document.body.classList.remove("sidebar-hidden");
    } else {
      document.body.classList.add("sidebar-hidden");
    }
  }

  /* ── Active nav links ───────────────────────────────────────────────── */
  function markActive() {
    var path = window.location.pathname.replace(/\/$/, "") || "/";
    document
      .querySelectorAll(".navbar nav a[href], .mobile-main-nav a[href]")
      .forEach(function (a) {
        var href = a.getAttribute("href").replace(/\/$/, "") || "/";
        a.classList.toggle("active", href === path);
      });
  }

  /* ── DOMContentLoaded ───────────────────────────────────────────────── */
  document.addEventListener("DOMContentLoaded", function () {
    // IMPORTANT FIX: Inject 'sidebar-wrap' class to the parent div so CSS can position it!
    var sidebarEl = document.querySelector(".sidebar");
    if (
      sidebarEl &&
      sidebarEl.parentElement &&
      sidebarEl.parentElement.tagName === "DIV"
    ) {
      sidebarEl.parentElement.classList.add("sidebar-wrap");
    }

    syncCodeTheme(getPreferred());

    document.querySelectorAll(".content img").forEach(function (img) {
      if (!img.getAttribute("loading")) {
        img.setAttribute("loading", "lazy");
      }
    });

    var themeBtn = document.getElementById("theme-toggle");
    if (themeBtn) {
      themeBtn.addEventListener("click", function () {
        var current =
          document.documentElement.getAttribute("data-theme") === "dark"
            ? "dark"
            : "light";
        var next = current === "dark" ? "light" : "dark";
        applyTheme(next);
        localStorage.setItem(THEME_KEY, next);
      });
    }

    /* --- Sidebar & Overlay logic --- */
    var sidebarBtn = document.getElementById("sidebar-toggle");
    var overlay = document.createElement("div");
    overlay.className = "sidebar-overlay";
    document.body.appendChild(overlay);

    function closeMobileSidebar() {
      document.body.classList.remove("mobile-sidebar-open");
    }

    overlay.addEventListener("click", closeMobileSidebar);

    if (sidebarBtn) {
      if (window.innerWidth > 768) {
        applySidebar(getSidebarState());
      } else {
        document.body.classList.remove("sidebar-hidden");
      }

      sidebarBtn.addEventListener("click", function () {
        if (window.innerWidth > 768) {
          var isVisible = !document.body.classList.contains("sidebar-hidden");
          applySidebar(!isVisible);
          localStorage.setItem(SIDEBAR_KEY, isVisible ? "hidden" : "visible");
        } else {
          document.body.classList.toggle("mobile-sidebar-open");
        }
      });
    }

    if (sidebarEl) {
      sidebarEl.addEventListener("click", function (e) {
        if (window.innerWidth <= 768 && e.target.tagName === "A") {
          closeMobileSidebar();
        }
      });
    }

    window.addEventListener("resize", function () {
      if (window.innerWidth > 768) {
        closeMobileSidebar();
      }
    });

    processAbbreviations();
    buildSidebarTOC();
    initScrollspy();
    markActive();
    initCopyBlock();
    initLightbox();
    initReadingProgress();
    initBackToTop();
    initAnchorLinks();

    var rawTextContent = document.body.textContent || document.body.innerText;
    if (
      rawTextContent.includes("$$") ||
      rawTextContent.includes("\\[") ||
      rawTextContent.includes("\\(")
    ) {
      renderMath();
    }
  });
})();
</script>
{{end}}
